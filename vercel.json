{
  "version": 2,
  "installCommand": "bun install --cwd backend && bun install --cwd frontend",
  "buildCommand": "bun run --cwd frontend build",
  "functions": {
    "api/[...all].js": {
      "includeFiles": "frontend/dist/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/[...all].js"
    }
  ]
}