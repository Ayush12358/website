{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "bun run build",
    "devCommand": "bun run dev",
    "installCommand": "bun install",
    "bunVersion": "1.x",
    "framework": null,
    "rewrites": [
        {
            "source": "/((?!api/.*).*)",
            "destination": "/index.html"
        }
    ],
    "outputDirectory": "dist"
}
